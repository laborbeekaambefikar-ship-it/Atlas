<?xml version='1.0'?>
<sdf version='1.6'>
<world name='atlas_warehouse'>
  <!-- ═══════════════════════════════════════════════════════════════
       ATLAS PROFESSIONAL WAREHOUSE — Industry 4.0 Showcase
       Navigation tape positions are LOCKED — do not modify:
         Spine: x=0, y=0..12
         Aisles: y=2,4,6,8,10 from x=0..5
         Home dock: (0, 0, yaw=90deg)
       ═══════════════════════════════════════════════════════════════ -->

  <gravity>0 0 -9.81</gravity>
  <physics type='ode'>
    <max_step_size>0.001</max_step_size>
    <real_time_factor>1.0</real_time_factor>
    <real_time_update_rate>1000</real_time_update_rate>
    <ode>
      <solver><type>quick</type><iters>50</iters></solver>
    </ode>
  </physics>

  <!-- ═══ SCENE + LIGHTING ═══ -->
  <scene>
    <ambient>0.4 0.4 0.45 1</ambient>
    <background>0.15 0.15 0.2 1</background>
    <shadows>1</shadows>
  </scene>


  <!-- Main warehouse LED lighting array -->
  <light name='led_bay_1' type='point'>
    <pose>2 3 4.5 0 0 0</pose>
    <diffuse>0.95 0.92 0.85 1</diffuse>
    <specular>0.3 0.3 0.3 1</specular>
    <attenuation><range>12</range><constant>0.3</constant><linear>0.05</linear><quadratic>0.01</quadratic></attenuation>
    <cast_shadows>true</cast_shadows>
  </light>
  <light name='led_bay_2' type='point'>
    <pose>2 7 4.5 0 0 0</pose>
    <diffuse>0.95 0.92 0.85 1</diffuse>
    <specular>0.3 0.3 0.3 1</specular>
