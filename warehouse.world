  <light name='led_dock' type='spot'>
    <pose>0 0 4.0 0 1.5708 0</pose>
    <diffuse>0.8 0.9 1.0 1</diffuse>
    <specular>0.2 0.2 0.3 1</specular>
    <attenuation><range>6</range><constant>0.5</constant><linear>0.1</linear><quadratic>0.02</quadratic></attenuation>
    <spot><inner_angle>0.5</inner_angle><outer_angle>1.0</outer_angle><falloff>1.0</falloff></spot>
    <cast_shadows>true</cast_shadows>
  </light>
  <light name='ambient_fill' type='directional'>
    <pose>5 6 8 0 0 0</pose>
    <diffuse>0.25 0.25 0.28 1</diffuse>
    <specular>0.05 0.05 0.05 1</specular>
    <direction>-0.2 -0.1 -1</direction>
    <cast_shadows>false</cast_shadows>
  </light>


