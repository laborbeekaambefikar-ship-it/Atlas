<?xml version="1.0"?>
<robot name="atlasarm6" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!--  AtlasArm-6: 6-DOF Robotic Manipulator                            -->
  <!--  Joints: base_rotation, shoulder, elbow, wrist_pitch,              -->
  <!--          wrist_roll, end_effector                                   -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->

  <xacro:property name="PI" value="3.14159265359"/>

  <!-- Link dimensions (meters) -->
  <xacro:property name="base_radius" value="0.06"/>
  <xacro:property name="base_height" value="0.04"/>
  <xacro:property name="link1_length" value="0.15"/>
  <xacro:property name="link1_radius" value="0.04"/>
  <xacro:property name="link2_length" value="0.25"/>
  <xacro:property name="link2_radius" value="0.035"/>
  <xacro:property name="link3_length" value="0.22"/>
  <xacro:property name="link3_radius" value="0.03"/>
  <xacro:property name="link4_length" value="0.08"/>
  <xacro:property name="link4_radius" value="0.025"/>
  <xacro:property name="link5_length" value="0.06"/>
  <xacro:property name="link5_radius" value="0.022"/>
  <xacro:property name="ee_length" value="0.08"/>
  <xacro:property name="ee_radius" value="0.015"/>

  <!-- Masses (kg) -->
  <xacro:property name="base_mass" value="2.0"/>
  <xacro:property name="link1_mass" value="1.5"/>
  <xacro:property name="link2_mass" value="1.2"/>
  <xacro:property name="link3_mass" value="0.8"/>
  <xacro:property name="link4_mass" value="0.5"/>
  <xacro:property name="link5_mass" value="0.3"/>
  <xacro:property name="ee_mass" value="0.2"/>

  <!-- Inertia macros -->
  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+l*l)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+l*l)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- Materials -->
  <material name="dark_grey"><color rgba="0.3 0.3 0.3 1.0"/></material>
  <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material>
  <material name="light_grey"><color rgba="0.7 0.7 0.7 1.0"/></material>
  <material name="blue"><color rgba="0.2 0.4 0.8 1.0"/></material>
  <material name="silver"><color rgba="0.8 0.8 0.85 1.0"/></material>

  <!-- ═══════ WORLD LINK (fixed) ═══════ -->
  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════ BASE LINK ═══════ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_height/2}"/>
      <mass value="${base_mass}"/>
      <inertia ixx="${base_mass*(3*base_radius*base_radius+base_height*base_height)/12}"
               ixy="0" ixz="0"
               iyy="${base_mass*(3*base_radius*base_radius+base_height*base_height)/12}"
               iyz="0"
               izz="${base_mass*base_radius*base_radius/2}"/>
    </inertial>
  </link>

  <!-- ═══════ JOINT 1: Base Rotation (Yaw) ═══════ -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-PI}" upper="${PI}" velocity="1.5" effort="50"/>
    <dynamics damping="0.5" friction="0.2"/>
  </joint>

  <!-- ═══════ LINK 1 ═══════ -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link1_radius}" length="${link1_length}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link1_radius}" length="${link1_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="${link1_mass}" r="${link1_radius}" l="${link1_length}"/>
  </link>

  <!-- ═══════ JOINT 2: Shoulder (Pitch) ═══════ -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 ${link1_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-PI/2}" upper="${PI/2}" velocity="1.5" effort="80"/>
    <dynamics damping="0.5" friction="0.2"/>
  </joint>

  <!-- ═══════ LINK 2 (Upper Arm) ═══════ -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link2_radius}" length="${link2_length}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link2_radius}" length="${link2_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="${link2_mass}" r="${link2_radius}" l="${link2_length}"/>
  </link>

  <!-- ═══════ JOINT 3: Elbow (Pitch) ═══════ -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 ${link2_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-3*PI/4}" upper="${3*PI/4}" velocity="1.5" effort="50"/>
    <dynamics damping="0.3" friction="0.15"/>
  </joint>

  <!-- ═══════ LINK 3 (Forearm) ═══════ -->
  <link name="link3">
    <visual>
      <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link3_radius}" length="${link3_length}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link3_radius}" length="${link3_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="${link3_mass}" r="${link3_radius}" l="${link3_length}"/>
  </link>

  <!-- ═══════ JOINT 4: Wrist Pitch ═══════ -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 ${link3_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-2*PI/3}" upper="${2*PI/3}" velocity="2.0" effort="30"/>
    <dynamics damping="0.2" friction="0.1"/>
  </joint>

  <!-- ═══════ LINK 4 (Wrist 1) ═══════ -->
  <link name="link4">
    <visual>
      <origin xyz="0 0 ${link4_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link4_radius}" length="${link4_length}"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link4_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link4_radius}" length="${link4_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="${link4_mass}" r="${link4_radius}" l="${link4_length}"/>
  </link>

  <!-- ═══════ JOINT 5: Wrist Roll ═══════ -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 ${link4_length}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-PI}" upper="${PI}" velocity="2.5" effort="20"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ═══════ LINK 5 (Wrist 2) ═══════ -->
  <link name="link5">
    <visual>
      <origin xyz="0 0 ${link5_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link5_radius}" length="${link5_length}"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link5_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link5_radius}" length="${link5_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="${link5_mass}" r="${link5_radius}" l="${link5_length}"/>
  </link>

  <!-- ═══════ JOINT 6: End Effector Rotation ═══════ -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="end_effector_link"/>
    <origin xyz="0 0 ${link5_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-PI/2}" upper="${PI/2}" velocity="3.0" effort="10"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <!-- ═══════ END EFFECTOR LINK ═══════ -->
  <link name="end_effector_link">
    <visual>
      <origin xyz="0 0 ${ee_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${ee_radius}" length="${ee_length}"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${ee_length/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${ee_radius}" length="${ee_length}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="${ee_mass}" r="${ee_radius}" l="${ee_length}"/>
  </link>

  <!-- ═══════ TOOL CENTER POINT (TCP) ═══════ -->
  <joint name="tcp_joint" type="fixed">
    <parent link="end_effector_link"/>
    <child link="tcp_link"/>
    <origin xyz="0 0 ${ee_length}" rpy="0 0 0"/>
  </joint>
  <link name="tcp_link"/>

  <!-- ═══════ ROS2_CONTROL HARDWARE INTERFACE ═══════ -->
  <ros2_control name="atlasarm6_control" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="joint1">
      <command_interface name="position"><param name="min">-3.14159</param><param name="max">3.14159</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"><param name="min">-1.5708</param><param name="max">1.5708</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"><param name="min">-2.3562</param><param name="max">2.3562</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"><param name="min">-2.0944</param><param name="max">2.0944</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint5">
      <command_interface name="position"><param name="min">-3.14159</param><param name="max">3.14159</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="joint6">
      <command_interface name="position"><param name="min">-1.5708</param><param name="max">1.5708</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- Gazebo ros2_control plugin -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find atlasarm6_control)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- Gazebo link colors -->
  <gazebo reference="base_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="link1"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="link2"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="link3"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="link4"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="link5"><material>Gazebo/White</material></gazebo>
  <gazebo reference="end_effector_link"><material>Gazebo/DarkGrey</material></gazebo>

</robot>
